# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Authentication — set to 'false' to disable all auth globally (dev/testing only)
# When false: Firebase is not initialised, all routes are open, requests get a mock admin user
AUTH_REQUIRED=true

# Database (PostgreSQL)
DATABASE_URL=postgresql://polygentic:your_password@localhost:5432/polygentic_db
DATABASE_SSL=false

# Redis (for Bull Queue)
REDIS_HOST=localhost
REDIS_PORT=6379

# API-Football (Pro Plan)
API_FOOTBALL_KEY=your_api_football_key_here
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_DAILY_LIMIT=7500

# The Odds API
ODDS_API_KEY=your_odds_api_key_here
ODDS_API_BASE_URL=https://api.the-odds-api.com
ODDS_API_REGIONS=uk,eu
ODDS_API_MONTHLY_CREDIT_LIMIT=20000

# Polymarket Trading Agent
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
POLYMARKET_PRIVATE_KEY=0xYOUR_WALLET_PRIVATE_KEY_HERE         # Hex private key (with 0x prefix) — required for live trading
POLYMARKET_API_KEY=your_polymarket_api_key                    # Derived from private key via SDK (leave empty to auto-derive)
POLYMARKET_API_SECRET=your_polymarket_api_secret              # Derived from private key via SDK
POLYMARKET_API_PASSPHRASE=your_polymarket_api_passphrase      # Derived from private key via SDK
POLYMARKET_FUNDER_ADDRESS=                                    # Polymarket proxy wallet address (leave empty to use signer address)
POLYMARKET_SIGNATURE_TYPE=0                                   # 0=EOA, 1=POLY_PROXY, 2=GNOSIS_SAFE (default: 2)
POLYMARKET_BUDGET=500
POLYMARKET_TARGET_MULTIPLIER=3
POLYMARKET_LIVE_TRADING=false
POLYMARKET_MIN_EDGE=0.05
POLYMARKET_MIN_LIQUIDITY=1000
POLYMARKET_KELLY_FRACTION=0.25
POLYMARKET_MAX_POSITION_PCT=0.10
POLYMARKET_STOP_LOSS_PCT=0.30
POLYMARKET_MIN_CONFIDENCE=6
POLYMARKET_SCAN_CRON=*/30 * * * *

# Live Match Monitoring
LIVE_POLLING_INTERVAL_MS=30000
LIVE_MAX_CONCURRENT_MATCHES=10

# Anthropic (Claude — Analysis Agent)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
PREDICTION_MODEL=claude-sonnet-4-20250514

# Perplexity (Sonar — Research Agent)
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Trigger.dev (background task orchestration)
TRIGGER_SECRET_KEY=your_trigger_dev_secret_key_here

# Prediction Tuning
PREDICTION_MISPRICING_THRESHOLD=0.05
PREDICTION_HIGH_CONFIDENCE_THRESHOLD=60
PREDICTION_SIGNAL_WEIGHT_MISPRICING=0.40
PREDICTION_SIGNAL_WEIGHT_STATISTICAL=0.35
PREDICTION_SIGNAL_WEIGHT_API_FOOTBALL=0.25
